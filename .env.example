# Database Configuration
# Replace with your actual PostgreSQL connection# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pichaus?schema=public"
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pichaus?schema=public"

# Application
NODE_ENV="development"
AUTH_SECRET="replace-with-a-random-32+-char-secret"

# Upload Configuration
UPLOAD_DIR="public/uploads"
PHOTO_DIR="photos"
THUMBNAIL_DIR="thumbnails"
MAX_FILE_SIZE_MB="10"

# WebAuthn / Passkeys
# WEBAUTHN_RP_ID must match the domain users visit (no port, no protocol)
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="PicHaus"
# WEBAUTHN_ORIGIN must match the exact origin in the browser address bar
WEBAUTHN_ORIGIN="http://localhost:3000"

# Google OAuth (optional) — enables Google Sign-In when both values are set
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: <origin>/api/v1/auth/google/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
